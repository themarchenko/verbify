  "legal": {
    "backToLogin": "Back to sign in",
    "lastUpdated": "Last updated: April 2026",
    "termsTitle": "Terms of Service",
    "termsSection1Title": "1. Acceptance of Terms",
    "termsSection1Body": "By accessing and using the Verbify platform, you agree to be bound by these Terms of Service. Each language school operating on the platform may have additional terms specific to their institution.",
    "termsSection2Title": "2. Platform Usage",
    "termsSection2Body": "Verbify provides a white-label platform for language schools to deliver courses, lessons, and learning materials to their students. School owners and teachers are responsible for the content they create and publish.",
    "termsSection3Title": "3. Accounts and Access",
    "termsSection3Body": "Your account is created and managed by your language school. Access to courses and materials is determined by your school's subscription plan and enrollment settings. You are responsible for maintaining the confidentiality of your login credentials.",
    "termsSection4Title": "4. Intellectual Property",
    "termsSection4Body": "Course content, lesson materials, and other educational resources published on the platform belong to the respective language school. The Verbify platform, its design, and underlying technology are the property of Verbify.",
    "privacyTitle": "Privacy Policy",
    "privacySection1Title": "1. Information We Collect",
    "privacySection1Body": "We collect information necessary to provide the learning platform: your name, email address, learning progress, and quiz scores. Each school operates as an independent data controller for the student data within their environment.",
    "privacySection2Title": "2. How We Use Your Data",
    "privacySection2Body": "Your data is used to provide the learning experience, track progress, and improve the platform. Student data is isolated per school through row-level security and is only accessible to the teachers and owners of your school.",
    "privacySection3Title": "3. Data Storage and Security",
    "privacySection3Body": "All data is stored securely using industry-standard encryption. We use Supabase for data storage with row-level security policies that ensure strict data isolation between schools.",
    "privacySection4Title": "4. Your Rights",
    "privacySection4Body": "You have the right to access, correct, or delete your personal data. Contact your school administrator or reach out to us directly to exercise these rights."
  },
